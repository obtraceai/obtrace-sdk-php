{
  "name": "obtrace/sdk",
  "description": "Obtrace PHP SDK",
  "type": "library",
  "version": "2.0.0",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Obtrace\\Sdk\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Obtrace\\Sdk\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.2",
    "open-telemetry/sdk": "^1.0",
    "open-telemetry/api": "^1.0",
    "open-telemetry/exporter-otlp": "^1.0",
    "open-telemetry/sem-conv": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "scripts": {
    "test": "phpunit --testdox",
    "obtrace:check": "php -r \"require_once 'vendor/autoload.php'; Obtrace\\Sdk\\ObtraceClient::printSetupInstructions();\""
  },
  "extra": {
    "laravel": {
      "providers": [
        "Obtrace\\Sdk\\Laravel\\ObtraceServiceProvider"
      ]
    }
  }
}
